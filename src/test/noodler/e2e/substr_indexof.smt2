(set-logic QF_SLIA)
(set-info :status sat)
(declare-const x String)
(declare-const y String)
(declare-const u String)
(assert (= y (str.substr x 0 (+ 1 (str.indexof x "cd" 1)))))
(assert (str.in_re x (re.++ (re.range "d" "z") re.allchar (str.to_re "cd"))))
(assert (< 1 (str.len y)))
(assert (= u (str.++ (str.substr x 0 (str.indexof x "cd" 1)) "cd")))
(assert (distinct u y))
(check-sat)
